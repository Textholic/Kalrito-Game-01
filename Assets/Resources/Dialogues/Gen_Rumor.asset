  - character: 1
    faceSpriteName: 
    text: "\uC6A9\uC774\uC694? \uC544\uC9C1 \uADF8\uB7F0 \uAC74 \uBABB \uBD24\uB294\uB370,
      \uB354 \uAE4A\uC774 \uB0B4\uB824\uAC00\uBA74 \uC54C\uAC8C \uB420 \uAC83 \uAC19\uC740\uB370\uC694."
