  condition: 0
  lines:
  - character: 0
    faceSpriteName: 
    text: "\uC774 \uB358\uC804\uC774 \uC0DD\uAE34 \uAC8C \uBC8C\uC368 300\uB144\uB3C4
      \uB118\uC5C8\uB2E4\uB294 \uAC70 \uC544\uC138\uC694? \uC6D0\uB798\uB294 \uACE0\uB300
      \uC655\uAD6D\uC758 \uC9C0\uD558 \uCC3D\uACE0\uC600\uB2E4\uACE0 \uD558\uB354\uB77C\uACE0\uC694."
  - character: 1
    faceSpriteName: 
    text: "\uADF8\uB807\uAD70\uC694. \uADF8\uB798\uC11C \uAC00\uB054 \uC624\uB798\uB41C
      \uC720\uBB3C\uB4E4\uC774 \uB098\uC624\uB294 \uAC70\uAD70\uC694."
  - character: 0
    faceSpriteName: 
    text: "\uB9DE\uC544\uC694. \uADF8 \uC720\uBB3C\uB4E4\uC774 \uBAA8\uD5D8\uAC00\uB4E4\uC744
      \uBD88\uB7EC \uBAA8\uC73C\uACE0, \uADF8 \uBAA8\uD5D8\uAC00\uB4E4 \uB355\uBD84\uC5D0
      \uC800\uB294 \uC624\uB298\uB3C4 \uC5EC\uAD00\uC744 \uC6B4\uC601\uD560 \uC218
      \uC788\uB2F5\uB2C8\uB2E4, \uD558\uD558."
