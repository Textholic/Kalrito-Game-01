  m_Script: {fileID: 11500000, guid: e0923e44943703d459c2da5a00d26850, type: 3}
  m_Name: Gen_History
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSet
  condition: 0
  lines:
  - character: 0
    faceSprite: {fileID: 0}
    text: "\uC774 \uB358\uC804\uC774 \uC0DD\uAE34 \uAC8C \uBC8C\uC368 300\uB144\uB3C4
      \uB118\uC5C8\uB2E4\uB294 \uAC70 \uC544\uC138\uC694? \uC6D0\uB798\uB294 \uACE0\uB300
      \uC655\uAD6D\uC758 \uC9C0\uD558 \uCC3D\uACE0\uC600\uB2E4\uACE0 \uD558\uB354\uB77C\uACE0\uC694."
  - character: 1
    faceSprite: {fileID: 606589391, guid: e1c66b28b770a654c8870a1b94089aa1, type: 3}
    text: "\uADF8\uB7FC \uAC00\uBB38\uC774 \uACC4\uC18D\uD574\uC11C \uC5EC\uAD00\uC744
      \uC6B4\uC601\uD558\uACE0 \uC788\uB294\uAC74\uAC00?"
  - character: 0
    faceSprite: {fileID: 826436998, guid: 5e330bee152712b498017866e060d88d, type: 3}
    text: "\uAC00.....\uBB38?"
  - character: 1
    faceSprite: {fileID: 826436998, guid: 5e330bee152712b498017866e060d88d, type: 3}
    text: "...\uB2F9\uC2E0...\uC5EC\uAE30\uC5D0 \uC5BC\uB9C8\uB098 \uC624\uB798 \uC788\uC5C8\uB358
      \uAC70\uC9C0?"
  - character: 0
    faceSprite: {fileID: -193878362, guid: 5e330bee152712b498017866e060d88d, type: 3}
    text: "\uC5B4\uBA38, \uC5EC\uC790\uC758 \uBE44\uBC00\uC744 \uCE90\uBB3B\uB294\uAC74
      \uB098\uC05C \uD589\uB3D9\uC774\uB78D\uB2C8\uB2E4, \uBBF8\uC2A4\uD130."
  - character: 1
    faceSprite: {fileID: 516009024, guid: e1c66b28b770a654c8870a1b94089aa1, type: 3}
    text: "\uC5EC....\uC790?"
  - character: 0
    faceSprite: {fileID: 1417953375, guid: 5e330bee152712b498017866e060d88d, type: 3}
    text: "\uB358\uC804\uC73C\uB85C \uAEBC\uC838 \uC774\uC790\uC2DD\uC544!!!"
