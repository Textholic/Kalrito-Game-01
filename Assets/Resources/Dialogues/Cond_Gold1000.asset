  - character: 0
    faceSpriteName: 
    text: "\uC5B4\uBA38\uB098! \uC8FC\uBA38\uB2C8\uAC00 \uC81C\uBC95 \uB450\uB451\uD574\uC9C0\uC168\uAD70\uC694.
