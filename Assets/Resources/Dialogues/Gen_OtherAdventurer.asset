  condition: 0
  lines:
  - character: 0
    faceSprite: {fileID: 0}
    text: "\uC5BC\uB9C8 \uC804\uC5D0 \uC740\uC0C9\uC758 \uAC11\uC8FC\uB97C \uB450\uB978
      \uBAA8\uD5D8\uAC00\uAC00 \uB2E4\uB140\uAC14\uC5C8\uB294\uB370, \uADF8 \uBD84\uB3C4
      \uC81C\uBC95 \uAE4A\uC774 \uB0B4\uB824\uAC00\uC168\uB354\uB77C\uACE0\uC694. "
  - character: 1
    faceSprite: {fileID: -942314562, guid: e1c66b28b770a654c8870a1b94089aa1, type: 3}
    text: "\uC624\uC624, \uC2E4\uB825\uC774 \uC788\uB294 \uC0AC\uB78C\uC778\uAC00
      \uBCF4\uAD70\uC694. \uD639\uC2DC \uBB50\uB77C\uACE0 \uD558\uB358\uAC00\uC694?"
  - character: 0
    faceSprite: {fileID: 0}
    text: "\"\uC80A\uC74C\uC774\uB780 \uBB34\uC5C7\uC778\uAC00? \uB4A4\uB3CC\uC544\uBCF4\uC9C0
      \uC54A\uB294 \uAC83\uC774\uACE0, \uC0AC\uB791\uC774\uB780 \uB9DD\uC124\uC774\uC9C0
      \uC54A\uB294 \uAC83\uC774\uB2E4\"\uB77C\uACE0 \uD558\uB354\uAD70\uC694."
  - character: 1
    faceSprite: {fileID: 1147038605, guid: e1c66b28b770a654c8870a1b94089aa1, type: 3}
    text: "\uC5B4\uB514\uC758 \uC6B0\uC8FC\uD615\uC0AC\uB0D0!!!!!"
